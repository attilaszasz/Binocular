{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Binocular: Debug API",
      "type": "debugpy",
      "request": "launch",
      "python": "/opt/homebrew/bin/python3.11",
      "module": "uvicorn",
      "args": [
        "backend.src.main:app",
        "--reload",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "BINOCULAR_DB_PATH": "${workspaceFolder}/data/binocular.db"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Binocular: Debug Frontend",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev",
        "--",
        "--host",
        "127.0.0.1",
        "--port",
        "5173",
        "--strictPort"
      ],
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "Local:\\s+https?://(?:127\\.0\\.0\\.1|localhost):5173/?",
        "uriFormat": "http://127.0.0.1:5173/",
        "action": "openExternally"
      }
    }
  ],
  "compounds": [
    {
      "name": "Binocular: Full Stack",
      "configurations": [
        "Binocular: Debug API",
        "Binocular: Debug Frontend"
      ]
    }
  ]
}