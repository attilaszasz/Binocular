{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Binocular: Debug API",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "backend.src.main:app",
        "--reload",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "BINOCULAR_DB_PATH": "${workspaceFolder}/data/binocular.db"
      },
      "console": "integratedTerminal"
    }
  ]
}