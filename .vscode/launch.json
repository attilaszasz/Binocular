{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Binocular: Debug API",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "backend.src.main:app",
        "--reload",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "BINOCULAR_DB_PATH": "${workspaceFolder}/data/binocular.db"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "Binocular: Debug Frontend",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev",
        "--",
        "--host",
        "127.0.0.1",
        "--port",
        "5173"
      ],
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "Local:\\s+(https?://[A-Za-z0-9._:/-]+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    }
  ],
  "compounds": [
    {
      "name": "Binocular: Full Stack",
      "configurations": [
        "Binocular: Debug API",
        "Binocular: Debug Frontend"
      ]
    }
  ]
}